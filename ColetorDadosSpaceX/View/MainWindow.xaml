<Window x:Class="ColetorDadosSpaceX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColetorDadosSpaceX"
        mc:Ignorable="d"
        Title="Painel de Coleta - SpaceX" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Sincronizar Dados" Click="BtnSincronizar_Click" Width="150" Height="30" Margin="5"/>

            <Button Content="Enviar para Nuvem" Click="BtnEnviar_Click" Width="150" Height="30" Margin="5" Background="Green" Foreground="White"/>
            <TextBlock Text="Total de Lançamentos:" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
            <TextBlock Text="{Binding LaunchStats.TotalLaunches}" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <TextBlock Text="Taxa de Sucesso:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
            <TextBlock Text="{Binding LaunchStats.SuccessRate, StringFormat={}{0:F2}%}" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Launches}" 
                  AutoGenerateColumns="True" IsReadOnly="True" />
    </Grid>
</Window>
